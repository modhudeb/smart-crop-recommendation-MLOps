# ---------------------------------------------------------------------------
# DVC and experiment-tracking runtime state
#
# Keep .dvc/config, dvc.yaml, dvc.lock, and params.yaml in Git. Those files
# demonstrate the MLOps pipeline. Ignore only local caches and generated runs.
# ---------------------------------------------------------------------------
.dvc/cache/
.dvc/tmp/
.dvc/config.local
mlruns/
mlartifacts/
wandb/
lightning_logs/

# ---------------------------------------------------------------------------
# Generated pipeline outputs
#
# Directory structure is kept with .gitkeep files. Data and model binaries
# should be reproduced through DVC or stored in an artifact registry.
# ---------------------------------------------------------------------------
data/raw/*
data/processed/*
data/features/*
data/splits/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/features/.gitkeep
!data/splits/.gitkeep

artifacts/**/*.joblib
artifacts/**/*.pkl
artifacts/**/*.pickle
artifacts/**/*.onnx
artifacts/**/*.pt
artifacts/**/*.pth
artifacts/**/*.h5
artifacts/**/*.keras
!artifacts/**/.gitkeep

# Deployment artifact copies are large binaries; keep app source files tracked.
app/*.joblib
app/*.pkl
app/*.pickle
app/*.onnx
app/*.pt
app/*.pth
app/*.h5
app/*.keras

# Runtime logs are useful locally but noisy in Git.
reports/logs/*
!reports/logs/.gitkeep
*.log

# ---------------------------------------------------------------------------
# Keep report evidence visible
#
# Do not ignore reports/metrics, reports/figures, or images. These are useful
# for showing model evaluation, diagnostics, and MLOps outcomes on GitHub.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
